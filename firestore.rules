rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /restaurants/{restaurantId} {
      allow read: if true;
      
      match /staff/{staffId} {
        allow read, write: if true;
      }
      
      match /orders/{orderId} {
        allow read, write: if true; // In production, add security (e.g. request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId)
      }
      
      match /tables/{tableId} {
        allow read: if true;
      }
      
      match /sessions/{sessionId} {
        allow read, write: if true;
      }
    }
  }
}
